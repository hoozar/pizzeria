<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Welcome to our pizzeria!</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="{{ asset('styles/app.css') }}" />
</head>
<body>
{# read and display all flash messages #}
{% for label, messages in app.flashes %}
    {% for message in messages %}
        <div class="alert alert-{{ label }}" role="alert">
            {{ message }}
        </div>
    {% endfor %}
{% endfor %}

<div class="alert alert-info" role="alert">
    {% if queue.count < 2 %}
        There is
    {% else %}
        There are
    {% endif %}
    {{ queue.count }} orders in queue with {{ queue.quantity }} pizzas in preparation, which will take about {{ queue.waitTime }} minutes
</div>


<h1>Welcome to our Best-In-Town Pizzeria!<br/>No one can BIT us, so Let Eat Be!</h1>
<br/>
<h2>Choose the delicious pizza</h2>

<div class="container text-center">
    <div class="row p-2 border border-warning">
        <div class="col"><b>Name</b></div>
        <div class="col"><b>Description</b></div>
        <div class="col"><b>Price</b></div>
        <div class="col"><b>Picture</b></div>
    </div>
    {%  for menuItem in menuItems %}
        <div class="row p-2 border border-warning">
            <div class="col">
                {{ menuItem.getName() }}
            </div>
            <div class="col">
                {{ menuItem.getDescription() }}
            </div>
            <div class="col">
                {{ menuItem.getPrice() }}
            </div>
            <div class="col">
                {% if menuItem.picture is empty %}
                    <img src="{{ '/picture/menu/noimage.png' }}" alt="No image" width="180px" height="180px" />
                {% else %}
                    <img src="{{ '/picture/menu/' ~ menuItem.getPicture() }}" alt="Menu image" width="180px" height="180px" />
                {% endif %}
            </div>
        </div>
    {% endfor %}
</div>

<div class="container text-left">
    <div class="row">
        <div class="col" style="padding: 50px;">{{ form(form) }}</div>
    </div>
</div>

<br />

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>
</html>
